[wsl2]
# networkingMode=mirrored
autoProxy=true

# 资源限制：建议使用具体单位（GB），比长串字节数更易维护
memory=6GB
processors=8
swap=4GB

defaultVhdSize=40GB

# Podman不支持UNC，所以关闭了，想要用的话可以安装docker
#   "containerEnv": {
#   "DISPLAY": null,
#   "WAYLAND_DISPLAY": null
# }
guiApplications=false
# guiApplications=true

[experimental]
# 内存自动回收：当 Linux 内部不再使用内存时，自动归还给 Windows
autoMemoryReclaim=gradual

# DNS 优化：提高在复杂网络环境（如 VPN/代理）下的域名解析成功率
bestEffortDnsParsing=true