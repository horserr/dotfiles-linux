# 服务器别名（自定义，如 my-cloud-server）
Host TEMPLATE
  # 服务器公网 IP 或域名
  HostName 123.45.67.89
  # 登录用户名（如 root、ubuntu、centos）
  User ubuntu
  # 私钥文件路径（绝对路径，如 ~/Downloads/my-server-key.pem）
  IdentityFile ~/Downloads/my-server-key.pem
  IdentitiesOnly yes
  # 可选：SSH 端口（默认 22，若云服务器改了端口需填写）
  Port 22
  # 可选：保持连接（避免超时断开）
  ServerAliveInterval 60
  # 可选：禁用严格主机密钥检查（首次连接无需确认指纹，不推荐生产环境）
  # StrictHostKeyChecking no
  ForwardAgent yes

Host Nvidia
  HostName nvidia-desktop.local
  User nvidia
  ForwardAgent yes

Host horserr
  HostName nvidia-desktop.local
  User horserr
  ForwardAgent yes

Host HuaWeiRoot
  HostName 1.94.8.97
