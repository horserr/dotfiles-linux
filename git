[core]
	editor = \"O:\\Programs\\Microsoft VS Code\\bin\\code\" --wait
[user]
	name = horserr
	email = 112157036+horserr@users.noreply.github.com
[alias]
	st = status --short
	l = log --oneline
	b = branch
	ck = checkout
	no-edit = commit --amend --no-edit
	d = difftool --dir-diff
[diff]
	tool = vscode
[difftool "vscode"]
	cmd = code --wait --diff $LOCAL $REMOTE --new-window
[merge]
	tool = vscode
[mergetool "vscode"]
	cmd = code --wait $MERGED --new-window
[difftool]
	prompt = false
[init]
	defaultBranch = main
[http]
	proxy = http://localhost:7897
[https]
	proxy = http://localhost:7897
[credential]
	helper = wincred
