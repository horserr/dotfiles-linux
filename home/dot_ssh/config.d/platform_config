# usage: git clone gh:user/repo
Host gh
    HostName github.com
    User git
    IdentityFile ~/.ssh/github_ed25519
    PreferredAuthentications publickey

Host gitlab.com
    HostName gitlab.com
    User git
    IdentityFile ~/.ssh/gitlab_rsa

Host gitee.com
    HostName gitee.com
    User git
    IdentityFile ~/.ssh/gitee_rsa