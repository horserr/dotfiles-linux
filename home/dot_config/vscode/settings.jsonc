{
  "$schema": "vscode://schemas/settings/user",
  // vscode built_in icons: https://code.visualstudio.com/api/references/icons-in-labels
  "editor.tabSize": 2,
  "editor.indentSize": "tabSize",
  "editor.renderWhitespace": "selection",
  "editor.codeActionsOnSave": {
    // refer to https://www.byteplus.com/en/topic/513795?title=vscode-editor-codeactionsonsave-a-complete-guide
    "source.fixAll": "explicit",
    "source.organizeImports": "explicit"
  },
  "editor.guides.indentation": true,
  "editor.rulers": [80, 120],
  "workbench.colorCustomizations": {
    "[Vira*]": {
      "statusBar.debuggingBackground": "#80CBC433",
      "statusBar.debuggingForeground": "#80CBC4",
      "toolbar.activeBackground": "#80CBC426",
      "button.background": "#80CBC4",
      "button.hoverBackground": "#80CBC4cc",
      "extensionButton.separator": "#80CBC433",
      "extensionButton.background": "#80CBC414",
      "extensionButton.foreground": "#80CBC4",
      "extensionButton.hoverBackground": "#80CBC433",
      "extensionButton.prominentForeground": "#80CBC4",
      "extensionButton.prominentBackground": "#80CBC414",
      "extensionButton.prominentHoverBackground": "#80CBC433",
      "activityBarBadge.background": "#80CBC4",
      "activityBar.activeBorder": "#80CBC4",
      "activityBarTop.activeBorder": "#80CBC4",
      "list.inactiveSelectionIconForeground": "#80CBC4",
      "list.activeSelectionForeground": "#80CBC4",
      "list.inactiveSelectionForeground": "#80CBC4",
      "list.highlightForeground": "#80CBC4",
      "sash.hoverBorder": "#80CBC480",
      "list.activeSelectionIconForeground": "#80CBC4",
      "scrollbarSlider.activeBackground": "#80CBC480",
      "editorSuggestWidget.highlightForeground": "#80CBC4",
      "textLink.foreground": "#80CBC4",
      "progressBar.background": "#80CBC4",
      "pickerGroup.foreground": "#80CBC4",
      "tab.activeBorder": "#80CBC4",
      "tab.activeBorderTop": "#80CBC400",
      "tab.unfocusedActiveBorder": "#80CBC4",
      "tab.unfocusedActiveBorderTop": "#80CBC400",
      "tab.activeModifiedBorder": "#80CBC400",
      "notificationLink.foreground": "#80CBC4",
      "editorWidget.resizeBorder": "#80CBC4",
      "editorWidget.border": "#80CBC4",
      "settings.modifiedItemIndicator": "#80CBC4",
      "panelTitle.activeBorder": "#80CBC4",
      "breadcrumb.activeSelectionForeground": "#80CBC4",
      "menu.selectionForeground": "#80CBC4",
      "menubar.selectionForeground": "#80CBC4",
      "editor.findMatchBorder": "#80CBC4",
      "selection.background": "#80CBC440",
      "statusBarItem.remoteBackground": "#80CBC414",
      "statusBarItem.remoteHoverBackground": "#80CBC4",
      "statusBarItem.remoteForeground": "#80CBC4",
      "notebook.inactiveFocusedCellBorder": "#80CBC480",
      "commandCenter.activeBorder": "#80CBC480",
      "chat.slashCommandForeground": "#80CBC4",
      "chat.avatarForeground": "#80CBC4",
      "activityBarBadge.foreground": "#000000",
      "button.foreground": "#000000",
      "statusBarItem.remoteHoverForeground": "#000000"
    }
  },
  "editor.tokenColorCustomizations": {
    // "[*Dark*]": {
    //   "textMateRules": [
    //     {
    //       "scope": "ref.matchtext",
    //       "settings": {
    //         "foreground": "#fff"
    //       }
    //     }
    //   ]
    // }
  },
  "editor.wordWrap": "bounded",
  "workbench.commandPalette.showAskInChat": false,
  "workbench.editor.closeEmptyGroups": true,
  "explorer.autoOpenDroppedFile": true,
  "explorer.fileNesting.enabled": true,
  "explorer.excludeGitIgnore": false,
  // Search settings
  "search.exclude": {
    "**/.git": true,
    "**/.gitignore": true,
    "**/.idea": true,
    "**/.svn": true,
    "**/.vscode": true,
    "**/build": true,
    "**/tmp": true
  },
  "search.smartCase": true,
  "search.useGlobalIgnoreFiles": true,
  "search.useParentIgnoreFiles": true,
  "search.experimental.closedNotebookRichContentResults": true,
  "search.quickAccess.preserveInput": true,
  "search.searchEditor.reusePriorSearchConfiguration": true,
  "search.searchEditor.singleClickBehaviour": "peekDefinition",
  // "workbench.localHistory"
  // Skip
  "zenMode.fullScreen": false,
  "zenMode.restore": false,
  // "workbench.editor.titleScrollbarSizing": "large",
  //////////// NOTE: hide editor tabs
  // "workbench.editor.showTabs": "single",
  "workbench.editor.openPositioning": "right",
  "workbench.editor.showTabIndex": true,
  "workbench.editor.enablePreviewFromQuickOpen": true,
  "window.openFilesInNewWindow": "default",
  "window.openFoldersInNewWindow": "default",
  "window.titleSeparator": " 📍 ",
  "window.title": "${dirty}😉${rootNameShort}${separator}${activeEditorShort}",
  "window.commandCenter": false,
  "window.confirmBeforeClose": "keyboardOnly",
  "window.confirmSaveUntitledWorkspace": false,
  "window.density.editorTabHeight": "compact",
  "window.dialogStyle": "custom",
  "window.menuBarVisibility": "toggle",
  "window.newWindowProfile": "Default",
  "window.restoreWindows": "none",
  "window.systemColorTheme": "auto",
  //////////// IngelliSense ////////////////////////////////////////////////////
  "editor.suggestOnTriggerCharacters": true,
  "editor.tabCompletion": "on",
  // "editor.tabCompletion": "onlySnippets",
  // "triggercharac",
  "editor.quickSuggestions": {
    "comments": true,
    "strings": true,
    "other": true
  },
  // really useful: https://code.visualstudio.com/docs/editing/intellisense#_suggestion-selection
  "editor.suggestSelection": "recentlyUsedByPrefix",
  "editor.acceptSuggestionOnEnter": "smart",
  "editor.quickSuggestionsDelay": 100,
  "editor.suggest.localityBonus": true,
  "editor.wordBasedSuggestions": "matchingDocuments",
  "editor.parameterHints.enabled": true,
  "editor.snippetSuggestions": "inline", // the sorting order of snippet within quick suggestions
  //////////////////////////////////////////////////////////////////////////////
  //////////////////// Custom Setting //////////////////////////////////////////
  //////////////////////////////////////////////////////////////////////////////
  // "editor.wordWrapColumn": 80,
  "application.experimental.rendererProfiling": true,
  "chat.agent.maxRequests": 200,
  // copilot chat settings
  "chat.editor.fontSize": 17,
  "chat.editor.lineHeight": 1.4,
  "chat.editor.wordWrap": "on",
  "chat.edits2.enabled": true,
  "chat.mcp.discovery.enabled": {
    "claude-desktop": true,
    "windsurf": true,
    "cursor-global": true,
    "cursor-workspace": true
  },
  "chat.renderRelatedFiles": true,
  "debug.console.fontSize": 18,
  "debug.showBreakpointsInOverviewRuler": true,
  "diffEditor.experimental.showMoves": true,
  "editor.accessibilityPageSize": 14,
  "editor.accessibilitySupport": "off",
  "editor.bracketPairColorization.independentColorPoolPerBracketType": true,
  "editor.cursorBlinking": "smooth",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.cursorSurroundingLines": 5,
  "editor.foldingImportsByDefault": true,
  "editor.fontFamily": "FiraCode Nerd Font, LXGW Neo XiHei, 江西拙楷, 杨任东竹石体 Heavy, Consolas, Microsoft YaHei",
  "editor.fontLigatures": true,
  // Editor settings
  "editor.fontSize": 16,
  "editor.formatOnPaste": true,
  // "prettier.requireConfig": true,
  "editor.formatOnType": true,
  "editor.guides.bracketPairs": "active",
  "editor.detectIndentation": true,
  "editor.inlayHints.enabled": "offUnlessPressed",
  "editor.inlayHints.fontSize": 15,
  "editor.inlayHints.padding": true,
  "editor.inlineSuggest.edits.showCollapsed": true,
  "editor.inlineSuggest.showToolbar": "always",
  "editor.lineHeight": 1.55,
  "editor.lineNumbers": "relative",
  "editor.linkedEditing": true,
  "editor.minimap.showSlider": "always",
  "editor.smoothScrolling": true,
  "editor.suggest.preview": true,
  "editor.suggestFontSize": 17,
  "editor.wrappingStrategy": "simple",
  "explorer.confirmPasteNative": false,
  "explorer.copyRelativePathSeparator": "/",
  "explorer.incrementalNaming": "smart",
  "extensions.experimental.affinity": {
    "asvetliakov.vscode-neovim": 1,
    "GitHub.copilot-chat": 2,
    "vscodevim.vim": 1
    //Caveats: One issue with using the affinity setting is that each time you update your settings file, the Vim plugin will reload, which can take a few seconds. https://github.com/VSCodeVim/Vim#:~:text=VSCodeVim%20is%20too%20slow
  },
  "files.associations": {
    "*.wxml": "html",
    "*.wxs": "javascript",
    "*.wxss": "css",
    "*.svg": "html",
    "*.user-data": "yaml",
    "*.wslconfig": "toml",
    ".chezmoiignore": "gitignore"
  },
  "files.autoGuessEncoding": true,
  // File settings
  "files.autoSave": "onFocusChange",
  "files.exclude": {
    "**/.DS_Store": true,
    "**/.git": true,
    "**/.hg": true,
    "**/.idea": true,
    "**/.svn": true,
    "**/Thumbs.db": true
  },
  "files.readonlyFromPermissions": true,
  "files.simpleDialog.enable": true,
  "files.trimTrailingWhitespace": true,
  "git.autofetch": true,
  "git.blame.statusBarItem.enabled": true,
  "git.fetchOnPull": true,
  "git.terminalGitEditor": true,
  "git.timeline.showUncommitted": true,
  "github.copilot.chat.codesearch.enabled": true,
  "github.copilot.chat.editor.temporalContext.enabled": true,
  "github.copilot.chat.edits.temporalContext.enabled": true,
  "github.copilot.chat.generateTests.codeLens": true,
  "github.copilot.chat.languageContext.fix.typescript.enabled": true,
  "github.copilot.chat.languageContext.inline.typescript.enabled": true,
  "github.copilot.chat.languageContext.typescript.enabled": true,
  "github.copilot.chat.scopeSelection": true,
  "github.copilot.enable": {
    "*": false,
    "ahk2": true,
    "powershell": true
  },
  "github.copilot.nextEditSuggestions.enabled": true,
  "github.copilot.nextEditSuggestions.fixes": true,
  "http.experimental.systemCertificatesV2": true,
  "inlineChat.enableV2": true,
  "inlineChat.finishOnType": true,
  "markdown.preview.fontSize": 16,
  "markdown.preview.typographer": true,
  "notebook.cellToolbarLocation": {
    "default": "right",
    "jupyter-notebook": "left"
  },
  "notebook.cellToolbarVisibility": "hover",
  "notebook.defaultFormatter": "charliermarsh.ruff",
  "notebook.diff.overviewRuler": true,
  "notebook.formatOnCellExecution": true,
  "notebook.formatOnSave.enabled": true,
  "notebook.globalToolbar": false,
  "notebook.globalToolbarShowLabel": "dynamic",
  "notebook.insertFinalNewline": true,
  // "notebook.markup.fontFamily": "LXGW WenKai",
  "notebook.markup.fontFamily": "Comfortaa",
  "notebook.markup.fontSize": 19,
  "notebook.output.fontFamily": "AI楷",
  "notebook.output.fontSize": 17,
  "notebook.output.scrolling": true,
  "notebook.output.textLineLimit": 7,
  // jupyter notebook settings
  "notebook.output.wordWrap": true,
  "notebook.showCellStatusBar": "visibleAfterExecute",
  "notebook.codeActionsOnSave": {
    "notebook.source.fixAll": "explicit",
    "notebook.source.organizeImports": "explicit"
  },
  "npm.enableRunFromFolder": true,
  "overleaf-workshop.compileOnSave.enabled": false,
  "overleaf-workshop.pdfViewer.themes": {
    "dark": {
      "bgColor": "#303541",
      "fontColor": "#c8cee0"
    },
    "default": {
      "bgColor": "#303541",
      "fontColor": "#c8cee0"
    },
    "light": {
      "bgColor": "#e6e6e6",
      "fontColor": "#333333"
    }
  },
  "powershell.integratedConsole.showOnStartup": false,
  "powershell.integratedConsole.startInBackground": true,
  // Miscellaneous settings
  "settingsSync.ignoredExtensions": ["leetcode.vscode-leetcode"],
  "settingsSync.ignoredSettings": [
    "-python.locator",
    "-vim.autoSwitchInputMethod.defaultIM",
    "-vim.autoSwitchInputMethod.obtainIMCmd",
    "-vim.autoSwitchInputMethod.switchIMCmd",
    "-window.zoomLevel",
    "-files.dialog.defaultPath"
  ],
  // "terminal.integrated.commandsToSkipShell": ["matlab.interrupt"],
  "terminal.integrated.confirmOnExit": "hasChildProcesses",
  "terminal.integrated.copyOnSelection": true,
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.fontLigatures.enabled": true,
  "terminal.integrated.fontSize": 17,
  "terminal.integrated.fontWeight": "normal",
  "terminal.integrated.profiles.windows": {
    "PowerShell": {
      "source": "PowerShell",
      "icon": "terminal-powershell"
    },
    "Command Prompt": {
      "path": [
        "${env:windir}\\Sysnative\\cmd.exe",
        "${env:windir}\\System32\\cmd.exe"
      ],
      "args": [],
      "icon": "terminal-cmd"
    },
    "Git Bash": {
      "source": "Git Bash"
    },
    "Ubuntu-22.04 (WSL)": {
      "args": ["-d", "Ubuntu-22.04"],
      "path": "C:\\Windows\\System32\\wsl.exe"
    },
    "Windows PowerShell": {
      "path": "C:\\WINDOWS\\System32\\WindowsPowerShell\\v1.0\\powershell.exe"
    }
  },
  // Terminal settings
  "terminal.integrated.smoothScrolling": true,
  "terminal.integrated.suggest.enabled": true,
  "tinymist.lint.enabled": true,
  "tinymist.lint.when": "onType",
  "tinymist.preview.cursorIndicator": true,
  "tinymist.preview.invertColors": "auto",
  //////////////// Vim Settings ////////////////////////////////////
  "vim.argumentObjectClosingDelimiters": [")", "]", "}", ">"],
  "vim.argumentObjectOpeningDelimiters": ["(", "[", "{", "<"],
  "vim.argumentObjectSeparators": [",", ";"],
  "vim.autoSwitchInputMethod.defaultIM": "1033",
  "vim.autoSwitchInputMethod.enable": true,
  "vim.autoSwitchInputMethod.obtainIMCmd": "D:/path/im-select.exe",
  "vim.autoSwitchInputMethod.switchIMCmd": "D:/path/im-select.exe {im}",
  // Vim settings
  "vim.camelCaseMotion.enable": true,
  "vim.cursorStylePerMode.insert": "line-thin",
  "vim.cursorStylePerMode.normal": "block",
  "vim.cursorStylePerMode.replace": "underline",
  "vim.cursorStylePerMode.visual": "underline-thin",
  "vim.cursorStylePerMode.visualblock": "block-outline",
  "vim.cursorStylePerMode.visualline": "block-outline",
  "vim.enableNeovim": true,
  "vim.foldfix": true,
  "vim.gdefault": true,
  "vim.handleKeys": {
    "<C-d>": true,
    "<C-f>": false,
    "<C-k>": false
  },
  "vim.highlightedyank.enable": true,
  "vim.highlightedyank.textColor": "#615ea8",
  "vim.history": 20,
  "vim.ignorecase": true,
  "vim.incsearch": true,
  "vim.leader": ",",
  "vim.matchpairs": "(:),{:},[:],<:>",
  "vim.neovimPath": "C:\\Program Files\\Neovim\\bin\\nvim.exe",
  "vim.normalModeKeyBindingsNonRecursive": [
    {
      "before": ["g", "y"],
      "commands": ["editor.action.clipboardCopyAction"]
    },
    {
      "before": ["g", "p"],
      "commands": ["editor.action.clipboardPasteAction"]
    },
    {
      "before": ["j"],
      "after": ["g", "j"]
    },
    {
      "before": ["k"],
      "after": ["g", "k"]
    },
    {
      "before": ["w"],
      "after": ["<leader>", "w"]
    },
    {
      "before": ["b"],
      "after": ["<leader>", "b"]
    },
    {
      "before": ["K"],
      "commands": ["editor.action.showHover"]
    },
    {
      "before": ["%"],
      "commands": ["editor.action.jumpToBracket"]
    },
    {
      "before": ["g", "e"],
      "commands": ["editor.action.marker.nextInFiles"]
    },
    {
      "before": ["f"],
      "after": ["<leader>", "<leader>", "s"]
    },
    {
      "before": ["<leader>", "r"],
      "commands": ["workbench.action.tasks.reRunTask"]
    },
    {
      "before": ["<leader>", "e"],
      "commands": ["editor.action.rename"]
    },
    {
      "before": ["<leader>", "E"],
      "commands": ["editor.action.refactor"]
    },
    {
      "before": ["<leader>", "F"],
      "commands": ["workbench.action.findInFiles"]
    },
    {
      "before": ["<leader>", "z", "<leader>"],
      "commands": ["workbench.action.toggleZenMode"]
    },
    {
      "before": ["<leader>", "c", "<leader>"],
      "commands": ["workbench.action.toggleCenteredLayout"]
    },
    {
      "before": ["<leader>", "r", "<leader>"],
      "commands": ["workbench.action.files.toggleActiveEditorReadonlyInSession"]
    },
    {
      "before": ["<leader>", "f", "<leader>"],
      "commands": ["workbench.action.toggleFullScreen"]
    },
    {
      "before": ["<leader>", "<leader>", "r"],
      "commands": ["workbench.action.tasks.runTask"]
    },
    {
      "before": ["<leader>", "<leader>", "d"],
      "commands": ["workbench.action.debug.start"]
    },
    {
      "before": ["<space>", "l"],
      "commands": [
        {
          "command": "notebook.formatCell",
          "when": "inCompositeEditor"
        },
        {
          "command": "editor.action.formatDocument",
          "when": "!inCompositeEditor"
        }
      ]
    },
    {
      "before": ["<space>", "t"],
      "commands": ["workbench.action.reopenClosedEditor"]
    },
    {
      "before": ["<space>", "q"],
      "commands": ["workbench.action.closeActiveEditor"]
    },
    {
      "before": ["<space>", "w"],
      "commands": ["workbench.action.closeOtherEditors"]
    },
    {
      "before": ["<space>", "x"],
      "commands": ["revealInExplorer"]
    },
    {
      "before": ["<space>", "f"],
      "commands": ["workbench.action.quickOpen"]
    },
    {
      "before": ["<space>", "a"],
      "commands": ["workbench.action.showCommands"]
    },
    {
      "before": ["<space>", "S"],
      "commands": ["workbench.action.gotoSymbol"]
    },
    {
      "before": ["<space>", "s"],
      "commands": ["workbench.action.showAllSymbols"]
    },
    {
      "before": ["<space>", "r"],
      "commands": ["editor.action.goToReferences"]
    },
    {
      "before": ["<space>", "p"],
      "commands": ["workbench.action.pinEditor"],
      "when": "!activeEditorIsPinned"
    },
    {
      "before": ["<space>", "P"],
      "commands": ["workbench.action.unpinEditor"],
      "when": "activeEditorIsPinned"
    },
    {
      "before": ["<space>", "<space>"],
      "commands": ["workbench.action.openView"]
    },
    {
      "before": ["<c-w>", ","],
      "commands": ["workbench.action.copyEditorToNewWindow"]
    },
    {
      "before": ["<c-w>", "."],
      "commands": ["workbench.action.moveEditorToNewWindow"]
    },
    {
      "before": ["<c-w>", "/"],
      "commands": ["workbench.action.toggleEditorGroupLayout"]
    },
    {
      "before": ["<space>"],
      "commands": ["vspacecode.space"]
    },
    {
      "before": [","],
      "commands": [
        "vspacecode.space",
        {
          "command": "whichkey.triggerKey",
          "args": "m"
        }
      ]
    }
  ],
  "vim.visualModeKeyBindingsNonRecursive": [
    {
      "before": [";", "m"],
      "commands": [
        {
          "command": "editor.action.insertSnippet",
          "args": {
            "snippet": "$${TM_SELECTED_TEXT}$"
          }
        }
      ]
    },
    {
      "before": [";", "M"],
      "commands": [
        {
          "command": "editor.action.insertSnippet",
          "args": {
            "snippet": "$$${TM_SELECTED_TEXT}$$"
          }
        }
      ]
    },
    {
      "before": [";", "b"],
      "commands": ["markdown.extension.editing.toggleBold"]
    },
    {
      "before": [";", "i"],
      "commands": ["markdown.extension.editing.toggleItalic"]
    },
    {
      "before": [";", "c"],
      "commands": ["markdown.extension.editing.toggleCodeSpan"]
    },
    {
      "before": [";", "C"],
      "commands": ["markdown.extension.editing.toggleCodeBlock"]
    },
    {
      "before": [";", "t"],
      "commands": ["markdown.extension.checkTaskList"]
    },
    {
      "before": ["g", "y"],
      "commands": ["editor.action.clipboardCopyAction"]
    },
    {
      "before": ["g", "p"],
      "commands": ["editor.action.clipboardPasteAction"]
    },
    {
      "before": ["j"],
      "after": ["g", "j"]
    },
    {
      "before": ["k"],
      "after": ["g", "k"]
    },
    {
      "before": ["w"],
      "after": ["<leader>", "w"]
    },
    {
      "before": ["b"],
      "after": ["<leader>", "b"]
    },
    {
      "before": ["L"],
      "after": ["$"]
    },
    {
      "before": ["H"],
      "after": ["^"]
    },
    {
      "before": ["<C-i>"],
      "commands": ["inlineChat.start"]
    },
    {
      "before": ["<leader>", "E"],
      "commands": ["editor.action.refactor"]
    },
    {
      "before": ["<leader>", "f"],
      "commands": ["actions.find"]
    },
    {
      "before": ["<leader>", "F"],
      "commands": ["workbench.action.findInFiles"]
    },
    {
      "before": ["A"],
      "commands": ["editor.action.insertCursorAtEndOfEachLineSelected"]
    },
    {
      "before": [">"],
      "commands": ["editor.action.indentLines"]
    },
    {
      "before": ["<"],
      "commands": ["editor.action.outdentLines"]
    },
    {
      "before": ["<space>", "<space>"],
      "commands": ["editor.action.smartSelect.expand"]
    },
    // {
    //   "before": [";", "p"],
    //   "commands": ["editor.action.transformToPascalcase"]
    // },
    {
      "before": [";", "t"],
      "commands": ["editor.action.transformToTitlecase"]
    },
    // {
    //   "before": [";", ";"],
    //   "commands": ["editor.action.transformToCamelcase"]
    // },
    // {
    //   "before": [";", "s"],
    //   "commands": ["editor.action.transformToSnakecase"]
    // },
    // {
    //   "before": [";", "k"],
    //   "commands": ["editor.action.transformToKebabcase"]
    // },
    {
      "before": ["<space>", "l"],
      "commands": ["editor.action.formatSelection"]
    },
    {
      "before": ["s"],
      "commands": ["editor.action.surroundWithSnippet"]
    },
    {
      "before": ["<space>"],
      "commands": ["vspacecode.space"]
    },
    {
      "before": [","],
      "commands": [
        "vspacecode.space",
        {
          "command": "whichkey.triggerKey",
          "args": "m"
        }
      ]
    }
  ],
  "vim.operatorPendingModeKeyBindingsNonRecursive": [
    {
      "before": ["L"],
      "after": ["$"]
    },
    {
      "before": ["H"],
      "after": ["^"]
    }
  ],
  "vim.insertModeKeyBindingsNonRecursive": [
    {
      "after": ["<C-g>", "u", "<C-u>"],
      "before": ["<C-u>"]
    },
    {
      "after": ["<C-g>", "u", "<C-w>"],
      "before": ["<C-w>"]
    },
    // {
    //   "before": ["<C-i>"],
    //   "commands": ["inlineChat.start"]
    // },
    {
      "before": [";", "z"],
      "after": ["\\"]
    }, // backslash
    {
      "before": [";", "l"],
      "after": ["_"]
    },
    {
      "before": [";", "e"],
      "after": ["="]
    }, //equal
    {
      "before": [";", "a"],
      "after": ["+"]
    }, //add
    {
      "before": [";", "s"],
      "after": ["-"]
    }, //subtract
    {
      "before": [";", ";", "e"],
      "after": ["=", "="]
      // "when": "editorLangId == 'javascript'" no use
    },
    {
      "before": [";", "i"],
      "commands": ["editor.action.insertSnippet"]
    }
  ],
  "vim.insertModeKeyBindings": [
    // reference: https://code.visualstudio.com/docs/editing/userdefinedsnippets#_assign-keyboard-shortcuts-to-snippets
    // can also use "command": "type" https://code.visualstudio.com/docs/configure/keybindings#_command-arguments
    // { "before": ["j", "k"], "after": ["<esc>"] },
    {
      "before": [";", "<Space>"],
      "commands": ["editor.action.triggerSuggest"]
    },
    {
      "before": [";", ";", "<Space>"],
      "commands": ["editor.action.triggerParameterHints"]
    },
    // suppress auto close brackets
    {
      "before": ["\""],
      "commands": [
        {
          "command": "editor.action.insertSnippet",
          "args": {
            "snippet": "\"$1\"$0"
          }
        }
      ]
    },
    {
      "before": [";", "f"],
      "commands": [
        {
          "command": "editor.action.insertSnippet",
          "args": {
            "snippet": "($1)$0"
          }
        }
      ]
    },
    {
      "before": [";", "v"],
      "commands": [
        {
          "command": "editor.action.insertSnippet",
          "args": {
            "snippet": "{$1}$0"
          }
        }
      ]
    },
    {
      "before": [";", "b"],
      "commands": [
        {
          "command": "editor.action.insertSnippet",
          "args": {
            "snippet": "[$1]$0"
          }
        }
      ]
    },
    {
      "before": [";", ";", "b"],
      "commands": [
        {
          "command": "editor.action.insertSnippet",
          "args": {
            "snippet": "[$1][$2]$0"
          }
        }
      ]
    }
    // cannot use when clause here
    // https://github.com/VSCodeVim/Vim/issues/1372#issuecomment-450553106
    // {
    //   "before": [";", ";", "e"],
    //   "commands": [
    //     {
    //       "command": "editor.action.insertSnippet",
    //       "args": {
    //         "snippet": "=="
    //       },
    //     },
    //     {
    //       "command": "editor.action.insertSnippet",
    //       "args": {
    //         "snippet": "="
    //       },
    //       "when": "editorLangId == 'javascript'"
    //     },
    //   ]
    // }
  ],
