    "Prettier.prettier-vscode",
    "Gruntfuggly.todo-tree",
    "tamasfe.even-better-toml"
  ],
  "python.languageServer": "Pylance",
  "python.analysis.autoFormatStrings": true,
  "python.analysis.completeFunctionParens": true,
  "python.analysis.importFormat": "relative",
  "python.analysis.inlayHints.functionReturnTypes": true,
  "python.analysis.inlayHints.pytestParameters": true,
  "python.analysis.inlayHints.variableTypes": true,
  "python.analysis.typeCheckingMode": "standard",
  "python.analysis.enableTroubleshootMissingImports": true,
  "python.analysis.cacheLSPData": true,
  "python.analysis.aiHoverSummaries": true,
  "python.analysis.typeEvaluation.enableReachabilityAnalysis": true,
  "python.analysis.inlayHints.callArgumentNames": "partial",
  "python.analysis.autoImportCompletions": true,
  "python.analysis.diagnosticMode": "workspace",
  "python.analysis.enableAsyncProgram": true,
  "python.analysis.findRefsInBackgroundThread": true,
  "python.analysis.generateWithTypeAnnotation": true,
  "python.analysis.includeAliasesFromUserFiles": true,
  "python.analysis.referencesCodeLens": true,
  "python.analysis.showOnlyDirectDependenciesInAutoImport": true,
  "python.analysis.supportAllPythonDocuments": true,
  "python.analysis.supportDocstringTemplate": true,
  "python.analysis.typeEvaluation.enableExperimentalFeatures": true,
  "python.analysis.typeEvaluation.strictListInference": true,
  // 在悬停提示中显示参数类型
  "python.analysis.diagnosticSeverityOverrides": {
    "reportUnusedImport": "information" // 将未使用的导入标记为蓝色信息而非警告
  },
  "python.analysis.exclude": ["**/node_modules", "**/venv", "**/.git"],
  "chat.fontSize": 17,
  "chat.fontFamily": "LXGW Wenkai",
  "chat.agent.thinking.collapsedTools": "withThinking",
  "terminal.external.windowsExec": "wt",
  // "markdown.styles": [".vscode/custom-style.css"],
  "[vue]": {
    "editor.defaultFormatter": "Vue.volar"
  },
  "workbench.iconTheme": "catppuccin-mocha",
  "git.blame.ignoreWhitespace": true,
  "git.mergeEditor": true,
  "git.inputValidation": true,
  "git.showPushSuccessNotification": true,
  "git.supportCancellation": true,
  "git.blame.editorDecoration.disableHover": true,
  "gitlens.graph.layout": "editor",
  "gitlens.views.scm.grouped.views": {
    "commits": false,
    "branches": false,
    "remotes": false,
    "stashes": false,
    "tags": false,
    "worktrees": false,
    "contributors": false,
    "fileHistory": false,
    "repositories": false,
    "searchAndCompare": false,
    "launchpad": false
  },
  "editor.codeLensFontSize": 16,
  "editor.minimap.sectionHeaderFontSize": 14,
  "gitlens.currentLine.fontSize": 16,
  "python.analysis.typeEvaluation.strictDictionaryInference": true,
  "python.analysis.typeEvaluation.strictSetInference": true,
  "python.terminal.activateEnvInCurrentTerminal": true,
  "github.copilot.chat.notebook.enhancedNextEditSuggestions.enabled": true,
  "github.copilot.chat.tools.memory.enabled": true,
  "python-envs.terminal.autoActivationType": "shellStartup",
  "editor.inlayHints.fontFamily": "Comic Sans MS",
  "javascript.inlayHints.functionLikeReturnTypes.enabled": true,
  "javascript.inlayHints.propertyDeclarationTypes.enabled": true,
  "javascript.inlayHints.variableTypes.enabled": true,
  "typescript.inlayHints.enumMemberValues.enabled": true,
  "typescript.inlayHints.functionLikeReturnTypes.enabled": true,
  "typescript.inlayHints.propertyDeclarationTypes.enabled": true,
  "typescript.inlayHints.parameterTypes.enabled": true,
  "typescript.inlayHints.variableTypes.enabled": true,
  "python.analysis.logLevel": "Warning",
  "python.analysis.typeEvaluation.disableBytesTypePromotions": true,
  "python.analysis.typeEvaluation.deprecateTypingAliases": true,
  "python.analysis.useNearestConfiguration": true,
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "diffEditor.ignoreTrimWhitespace": true,
  "github.copilot.nextEditSuggestions.extendedRange": true,
  "diffEditor.hideUnchangedRegions.enabled": true,
  // "markdown.extension.preview.autoShowPreviewToSide": true,
  "markdowntable.showMenu.csvToTable": true,
  "xlsxViewer.md.stickyToolbar": true,
  "xlsxViewer.md.wordWrap": true,
  "xlsxViewer.md.syncScroll": true,
  "xlsxViewer.md.previewPosition": "right",
  "xlsxViewer.md.showOutline": false,
  "markdown-preview-enhanced.previewTheme": "github-dark.css",
  "json.schemaDownload.trustedDomains": {
    "https://schemastore.azurewebsites.net/": true,
    "https://raw.githubusercontent.com/": true,
    "https://www.schemastore.org/": true,
    "https://json.schemastore.org/": true,
    "https://json-schema.org/": true,
    "https://aka.ms": true
  },
  "workbench.editor.useModal": "some",
  "terminal.integrated.enableImages": true,
  "chat.viewProgressBadge.enabled": true,
  "chat.viewSessions.orientation": "stacked",
  "chat.tools.terminal.sandbox.enabled": true,
  "update.enableWindowsBackgroundUpdates": true
}
