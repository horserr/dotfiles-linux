{
	// Place your snippets for pyproject-toml here. Each snippet is defined under a snippet name and has a prefix, body and
	// description. The prefix is what is used to trigger the snippet and the body will be expanded and inserted. Possible variables are:
	// $1, $2 for tab stops, $0 for the final cursor position, and ${1:label}, ${2:another} for placeholders. Placeholders with the
	// same ids are connected.
	// Example:
	// "Print to console": {
	// 	"prefix": "log",
	// 	"body": [
	// 		"console.log('$1');",
	// 		"$2"
	// 	],
	// 	"description": "Log output to console"
	// }
	"uv pytorch config": {
		"prefix": "pytorch index",
		"body": [
			"[[tool.uv.index]]",
			"name = \"pytorch-cu128\"",
			"# url = \"https://download.pytorch.org/whl/cu128\"",
			"url = \"https://mirrors.nju.edu.cn/pytorch/whl/cu128\"",
			"explicit = true",
			"",
			"[tool.uv.sources]",
			"torch = { index = \"pytorch-cu128\" }",
			"# torchao = { index = \"pytorch-cu128\" }",
			"# torchrl = { index = \"pytorch-cu128\" }",
		],
		"description": "Add pytorch configuration in project based"
	},
	"sample complete template": {
		"prefix": "sample template",
		"isFileTemplate": true,
		"body": [
			"dependencies = [",
			"    \"beartype>=0.22.9\",",
			"    \"einops>=0.8.1\",",
			"    \"jaxtyping>=0.3.5\",",
			"    \"rich>=14.3.1\",",
			"    \"safetensors>=0.7.0\",",
			"    \"torch>=2.10.0\",",
			"]",
			"",
			"[[tool.uv.index]]",
			"name = \"pytorch-cu128\"",
			"url = \"https://download.pytorch.org/whl/cu128\"",
			"explicit = true",
			"",
			"[tool.uv.sources]",
			"torch = { index = \"pytorch-cu128\" }",
			"",
			"[tool.ruff]",
			"# Exclude files and directories",
			"exclude = [\"__pycache__\", \".venv\", \"build\", \"dist\"]",
			"# Set the line length",
			"line-length = 88",
			"# Enable preview mode for the latest features",
			"preview = true",
			"",
			"[tool.ruff.lint]",
			"# Select the default rule sets (E, F, W, I, C4, B, etc.)",
			"select = [\"E\", \"F\", \"W\", \"I\", \"C4\", \"B\"]",
			"# Ignore specific rules globally, which mainly for jaxtyping",
			"ignore = [\"F821\", \"F722\"]",
			"",
			"[tool.ruff.format]",
			"# Like Black, use double quotes for strings.",
			"quote-style = \"double\"",
			"# Like Black, indent with spaces.",
			"indent-style = \"space\"",
			"",
			"[dependency-groups]",
			"dev = [",
			"    \"pytest>=9.0.2\",",
			"    \"ruff>=0.14.14\",",
			"]"
		],
		"description": "sample template for setting up development"
	}
}