	"Test CUDA": {
		"prefix": "",
		"body": [
			"# 导入pytorch核心库",
			"import torch",
			"",
			"# 1. 查看PyTorch版本",
			"print(f\"PyTorch 版本: {torch.__version__}\")",
			"",
			"# 2. 检测PyTorch是否编译了CUDA支持（即是否是CUDA版本）",
			"print(f\"\\nPyTorch 编译时是否支持 CUDA: {torch.cuda.is_available()}\")",
			"",
			"# 3. 若支持CUDA，打印更多详细信息（方便排查问题）",
			"if torch.cuda.is_available():",
			"    # 查看支持的CUDA版本（PyTorch编译时对应的CUDA版本，不是你系统安装的CUDA版本）",
			"    print(f\"PyTorch 对应的 CUDA 版本: {torch.version.cuda}\")",
			"    ",
			"    # 查看可用的GPU数量",
			"    gpu_count = torch.cuda.device_count()",
			"    print(f\"可用 GPU 数量: {gpu_count}\")",
			"    ",
			"    # 查看当前使用的GPU索引和名称",
			"    current_gpu = torch.cuda.current_device()",
			"    print(f\"当前使用的 GPU 索引: {current_gpu}\")",
			"    print(f\"当前 GPU 名称: {torch.cuda.get_device_name(current_gpu)}\")",
			"    ",
			"    # 验证GPU是否能正常执行张量运算",
			"    test_tensor = torch.tensor([1.0, 2.0, 3.0]).cuda()",
			"    print(f\"\\n测试张量（在GPU上）: {test_tensor}\")",
			"    print(f\"测试张量所在设备: {test_tensor.device}\")",
			"else:",
			"    print(\"\\n当前PyTorch不支持CUDA，可能是安装了CPU版本，或CUDA环境配置有误。\")"
		],
		"description": "Test CUDA"
	},
	"device": {
