{
	// Place your snippets for markdown here. Each snippet is defined under a snippet name and has a prefix, body and
	// description. The prefix is what is used to trigger the snippet and the body will be expanded and inserted. Possible variables are:
	// $1, $2 for tab stops, $0 for the final cursor position, and ${1:label}, ${2:another} for placeholders. Placeholders with the
	// same ids are connected.
	// Example:
	// "Print to console": {
	// 	"prefix": "log",
	// 	"body": [
	// 		"console.log('$1');",
	// 		"$2"
	// 	],
	// 	"description": "Log output to console"
	// }
	//
	// You can also restrict snippets to specific files using include/exclude patterns:
	// "Test snippet": {
	// 	"prefix": "test",
	// 	"body": "test('$1', () => {\n\t$0\n});",
	// 	"include": ["**/*.test.ts", "*.spec.ts"],
	// 	"exclude": ["**/temp/*.ts"],
	// 	"description": "Insert test block"
	// }
	"post frontmatter": {
		"prefix": "frontmatter",
		"body": [
			"---",
			"title: $1",
			"date: $CURRENT_YEAR-$CURRENT_MONTH-${CURRENT_DATE}T$CURRENT_HOUR:$CURRENT_MINUTE:$CURRENT_SECOND$CURRENT_TIMEZONE_OFFSET",
			"id: $UUID",
			"tags:",
			"  - $2",
			"---",
			"$0"
		],
		"description": "Post frontmatter"
	},
	"slidev frontmatter": {
		"prefix": "slides frontmatter",
		"body": [
			"---",
			"title: Research Overview",
			"drawings:",
			"  persist: false",
			"# slide transition: https://sli.dev/guide/animations.html#slide-transitions",
			"transition: view-transition",
			"class: text-center",
			"# enable MDC Syntax: https://sli.dev/features/mdc",
			"mdc: true",
			"theme: seriph",
			"monaco: true",
			"fonts:",
			"  sans: \"Roboto\"",
			"  serif: \"PT Serif\"",
			"  mono: \"Fira Code\"",
			"---"
		],
		"description": "Slidev frontmatter"
	},
	"Insert 2 cols table": {
		"prefix": "2 cols table",
		"body": [
			"|${0:title} |  |",
			"| - | - |",
			"|   |   |"
		],
		"description": "Insert a 2 cols table"
	},
	"Insert 3 cols table": {
		"prefix": "3 col table",
		"body": [
			"| title |     |     |",
			"| ----- | --- | --- |",
			"|       |     |     |"
		],
		"description": "Insert a 3 cols table"
	},
	"Github Note callout": {
		"prefix": "note callout",
		"body": [
			"> [!NOTE]",
			"> $TM_SELECTED_TEXT",
			"${1:> ${2:Highlights information that users should take into account, even when skimming.}}",
			"$0"
		],
		"description": "Github flavored NOTE callout"
	},
	"Github Tip callout": {
		"prefix": "tip callout",
		"body": [
			"> [!TIP]",
			"> $TM_SELECTED_TEXT",
			"${1:> ${2:Optional information to help a user be more successful.}}",
			"$0"
		],
		"description": "Github flavored TIP callout"
	},
	"Github Important callout": {
		"prefix": "important callout",
		"body": [
			"> [!IMPORTANT]",
			"> $TM_SELECTED_TEXT",
			"${1:> ${2:Critical information for users to know before continuing.}}",
			"$0"
		],
		"description": "Github flavored IMPORTANT callout"
	},
	"Github Caution callout": {
		"prefix": "caution callout",
		"body": [
			"> [!CAUTION]",
			"> $TM_SELECTED_TEXT",
			"${1:> ${2:Information that users need to be careful about.}}",
			"$0"
		],
		"description": "Github flavored CAUTION callout"
	},
	"Github Warning callout": {
		"prefix": "warning callout",
		"body": [
			"> [!WARNING]",
			"> $TM_SELECTED_TEXT",
			"${1:> ${2:Serious information that users must read to avoid significant consequences.}}",
			"$0"
		],
		"description": "Github flavored WARNING callout"
	}
}