# code: language=ini
# adapted from: https://github.com/mathiasbynens/dotfiles/blob/main/.gitconfig

#******************
#* CORE AND BASIC *
#******************
[core]
 	# Use custom `.gitignore` and `.gitattributes`.
	excludesfile = ~/.gitignore
	attributesfile = ~/.gitattributes

	# Treat spaces before tabs and all kinds of trailing whitespace as an error.
	# [default] trailing-space: looks for spaces at the end of a line
	# [default] space-before-tab: looks for spaces before tabs at the beginning of a line

	whitespace = space-before-tab,-indent-with-non-tab,trailing-space
	# Speed up commands involving untracked files such as `git status`.
	# https://git-scm.com/docs/git-update-index#_untracked_cache
	untrackedCache = true
[user]
	name = horserr
	email = 112157036+horserr@users.noreply.github.com
  signingkey = ~/.ssh/id_ed25519_signing.pub
[init]
	defaultBranch = main
[help]
	# Automatically correct and execute mistyped commands.
	autocorrect = 1
[credential]
	helper = cache
[grep]
	patternType = perl
[gpg]
	format = ssh
[branch]
	# Show most recently changed branches first.
	sort = -committerdate
[apply]
	# Detect whitespace errors when applying a patch.
	whitespace = fix
[commit]
  gpgsign = true
	signoff = true
[tag]
  gpgsign = true
[rerere]
	enable = true

#******************
#* MERGE AND DIFF *
#******************
[merge]
  conflictStyle = zdiff3
  tool = vscode
[mergetool.vscode]
  cmd = code --wait $MERGED

[diff]
	# Detect copies as well as renames.
	renames = copies
  tool = vscode
[diff "bin"]
	# Use `hexdump` to diff binary files.
	textconv = hexdump -v -C
[difftool.vscode]
  cmd = code --wait --diff $LOCAL $REMOTE

#*****************
#* PUSH AND PULL *
#*****************
[push]
	# https://git-scm.com/docs/git-config#git-config-pushdefault
	default = simple
	# Keep CLI push behavior aligned with VS Code's sync setting.
	# don't push tags by the way
	followTags = false
	recurseSubmodules = on-demand
[fetch]
	# Match VS Code's prune-on-fetch behavior.
	prune = true
[pull]
	# Match VS Code's rebase-when-sync behavior.
	rebase = true
[rebase]
	# Keep rebases conservative unless explicitly requested.
	autoStash = false
[blame]
	ignoreWhitespace = true
[submodule]
	recurse = true
#******************
#* URL SHORTHANDS *
#******************
[url "git@github.com:"]
	insteadOf = "gh:"
	pushInsteadOf = "github:"
	pushInsteadOf = "git://github.com/"
[url "git://github.com/"]
	insteadOf = "github:"
[url "git@gist.github.com:"]
	insteadOf = "gst:"
	pushInsteadOf = "gist:"
	pushInsteadOf = "git://gist.github.com/"
[url "git://gist.github.com/"]
	insteadOf = "gist:"

[color]
	# Use colors in Git commands that are capable of colored output when
	# outputting to the terminal. (This is the default setting in Git ≥ 1.8.4.)
	ui = auto
[color "branch"]
	current = yellow reverse
	local = yellow
	remote = green
[color "diff"]
	meta = yellow bold
	frag = magenta bold # line info
	old = red # deletions
	new = green # additions
[color "status"]
	added = yellow
	changed = green
	untracked = cyan

#*********
#* ALIAS *
#*********
[alias]
	repo = clone --depth 1
	w = worktree

	# log
	l = log --pretty=oneline --graph --abbrev-commit --no-merges
	la = log --all --pretty=oneline --graph --abbrev-commit --no-merges
	# log line
	ll = log --oneline --no-patch -L
	lll = log --oneline -L
	# log search
	ls = log --pretty=oneline --abbrev-commit -S
	# log match
	lS = log --no-merges --stat --regexp-ignore-case -G
	# log grep
	lgrep = log --grep
	# log conflicted commit messages
	lm = log --oneline --left-right --merge
	# REALLY usefule to find conflict commits
	lmm = log --oneline --left-right --merge --patch
	# log bifurcated(fork) commits
	lfork = log --oneline --left-right HEAD...MERGE_HEAD

	# show and status
	s = status --short --branch
	sd = diff --stat --ignore-space-change
	# what to be committed: diff between staged and the repo
	sdd = diff --stat --ignore-space-change --staged
	# show progress
	spro = describe --tags --always
	# show tag: followed by standard shell regex
	stag = tag -l
	# show conflict files
	sconflict = diff --name-only --diff-filter=U
	# show base
	sbase  = "!f() { git show :1:$1; }; f"
	# show ours
	sours = "!f() { git show :2:$1; }; f"
	# show theirs
	stheirs = "!f() { git show :3:$1; }; f"
	sb = branch --verbose
	sbb = branch --verbose --all
	# show merged branches
	sbmerge = branch --merged

	a = add --update
	aa = add .
	aaa = add --all

	b = blame -C -L

	c = commit
	ca = commit --all
	cam = commit --amend
	cne = commit --amend --no-edit
	cemp = commit --allow-empty

	# what modified: diff between working dir and staged
	d = diff --ignore-space-change
	# what to be committed: diff between staged and the repo
	dd = diff --ignore-space-change --staged
	# diff between
	ddd = diff --ignore-space-change HEAD
	dt = difftool
	dw = diff --word-diff --ignore-space-change
	# 对比两边的原始版本
	dours = diff --ours
	dtheirs = diff --theirs
	# 在还没开始改代码前，搞清楚对方的分支到底动了哪些文件
	dfork = diff HEAD...MERGE_HEAD

	# clean untracked files
	x = clean --dry-run
	xx = clean --force
	# clean ignored files or folders
	xi = clean -X --dry-run
	xxi = clean -X --force
	# clean untracked directories
	xd = clean -d --dry-run
	xxd = clean -d --force

	# interactive add/stage
	ia = add --patch
  iaa = add --interactive
  # Interactive rebase with the given number of latest commits.
	ir = rebase --interactive
	# interactive unstage
	iu = reset --patch
	# interactive stash
	is = stash --patch
	ik = stash --patch
	# Note: do not use: checkout --patch
	# interactivly clean ignored files or folders
	ix = clean -X --interactive

	# jump = switch
	j = switch
	jc = switch --create

  # k for keep, the sysnonym of stash
	k = stash
	kb = stash branch
	# keep index
	ki = stash --keep-index
	kk = stash --include-untracked # shortfor -u
	# all files, including ignored files
	kkk = stash --all

	m = merge -Xignore-space-change
	# use ours
	mours = merge -Xours
	re-merge = restore --conflict=merge

	unstage = restore --staged
	alias = config --get-regexp alias

	lost-found = fsck --lost-found
	freeze = update-index --assume-unchanged
	# todo
	# continue = rebase --continue
	# abort = rebase --abort

	pick = cherry-pick

	depth = fetch --depth
	deepen = fetch --deepen
	shallow-since = fetch --shallow-since
	unshallow = fetch --unshallow

	conf = config --global --edit
	whoami = config user.email

	# plumbing commands
	cat = cat-file -p
	# -r: recursive, -t: tree node, -l: show size
	lstree = ls-tree -r -t -l --abbrev # --name-only
	# list Index
	lsfile = ls-files
	lsignore = ls-files --others --ignored
	lsconflict = ls-file --unmerged # -u
	mergefile = merge-file -p # ours common theirs

	; root = "!cd $(git rev-parse --show-toplevel)"
	root = rev-parse --show-toplevel
	dir = rev-parse --show-prefix
	is-shallow = rev-parse --is-shallow-repository
	test-date = rev-parse --since


	# Note: the difference between ls-tree and ls-files:
		# ls-tree is applied to a specific commit or tree object
		# ls-files is applied to the Index(the staged files)

	# Find branches containing commit
	fb = "!f() { git branch -a --contains $1; }; f"

	# Find tags containing commit
	ft = "!f() { git describe --always --contains $1; }; f"

  # git log origin/main..HEAD  # show what is about to push
  # git log origin/main..      # for simplicity
	# show remote <name>
	# git fetch origin --prune/p <branch>
	# git push origin --delete <branch>
	# git filter-repo
	# git archive

	############
	# git reflog is equivalent to git log -g/--walk-reflogs --abbrev-commit --pretty=oneline
	# git subtree
	# git submodule
	# git rev-parse <branch>
