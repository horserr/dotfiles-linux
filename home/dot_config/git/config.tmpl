# code: language=ini
# adapted from: https://github.com/mathiasbynens/dotfiles/blob/main/.gitconfig

#******************
#* CORE AND BASIC *
#******************
[core]
	# excludesfile is default to $XDG_CONFIG_HOME/git/ignore
	# attributesfile is default to $XDG_CONFIG_HOME/git/attributes

	# Treat spaces before tabs and all kinds of trailing whitespace as an error.
	# [default] trailing-space: looks for spaces at the end of a line
	# [default] space-before-tab: looks for spaces before tabs at the beginning of a line

	whitespace = space-before-tab,-indent-with-non-tab,trailing-space
	# Speed up commands involving untracked files such as `git status`.
	# https://git-scm.com/docs/git-update-index#_untracked_cache
	untrackedCache = true
	ignoreCase = false
[user]
	name = horserr
	email = 112157036+horserr@users.noreply.github.com
  signingkey = ~/.ssh/id_ed25519_signing.pub
[init]
	defaultBranch = main
[help]
	# Automatically correct and execute mistyped commands.
	# after 10 seconds
	autocorrect = 100
[credential]
	helper = cache
[grep]
	patternType = perl
[gpg]
	format = ssh
[branch]
	# Show most recently changed branches first.
	sort = -committerdate
[pager]
	# use pager for git status
	status = true
[commit]
  template = ~/.config/git/message
  gpgsign = true
	signoff = true
[tag]
  gpgsign = true
[rerere]
	enable = true
[status]
	# show submodule summary when using git status
	submodulesummary = true

#******************
#* MERGE AND DIFF *
#******************
[merge]
  conflictStyle = zdiff3
  tool = vscode
	autoStash = true
[mergetool.vscode]
  cmd = code --wait $MERGED

[diff]
	# Detect copies as well as renames.
	renames = copies
	# external = vscode
  tool = vscode
	# show submodule log when using git diff
	submodule = log
[diff "bin"]
	# Use `hexdump` to diff binary files.
	textconv = hexdump -v -C
[difftool.vscode]
  cmd = code --wait --diff $LOCAL $REMOTE

#*****************
#* PUSH AND PULL *
#*****************
[push]
	# https://git-scm.com/docs/git-config#git-config-pushdefault
	default = simple
	# Keep CLI push behavior aligned with VS Code's sync setting.
	# don't push tags by the way
	followTags = false
	# recurseSubmodules = on-demand
	recurseSubmodules = check
[fetch]
	# Match VS Code's prune-on-fetch behavior.
	prune = true
[pull]
	# Match VS Code's rebase-when-sync behavior.
	rebase = true
[rebase]
	# autostash: Automatically create a temporary stash entry before the operation begins, and apply it after the operation ends. This means that you can run rebase on a dirty worktree. However, use with care: the final stash application after a successful rebase might result in non-trivial conflicts.
	autoStash = true
	# autosquash: When true, git rebase will automatically squash commits that begin with "squash!" or "fixup!" into the commit that they reference. This is useful for cleaning up commit history before merging a feature branch into the main branch.
	autosquash = true
[blame]
	ignoreWhitespace = true
[submodule]
	# Please refer to #file:refs/git_submodule_recurse_config.md for better illustration on why this setting is significant
	# does not affect `git clone`
	recurse = true
	# auto detect fetch jobs
	fetchJobs = 0
#******************
#* URL SHORTHANDS *
#******************
[url "git@github.com:"]
	insteadOf = "gh:"
	pushInsteadOf = "github:"
	pushInsteadOf = "git://github.com/"
[url "git://github.com/"]
	insteadOf = "github:"
[url "git@gist.github.com:"]
	insteadOf = "gst:"
	pushInsteadOf = "gist:"
	pushInsteadOf = "git://gist.github.com/"
[url "git://gist.github.com/"]
	insteadOf = "gist:"

[color]
	# Use colors in Git commands that are capable of colored output when
	# outputting to the terminal. (This is the default setting in Git ≥ 1.8.4.)
	ui = auto
[color "branch"]
	current = yellow reverse
	local = yellow
	remote = green
[color "diff"]
	meta = yellow bold
	frag = magenta bold # line info
	old = red # deletions
	new = green # additions
[color "status"]
	added = yellow
	changed = green
	untracked = cyan

[include]
	path = alias

# GitHub 用个人邮箱
[includeIf "hasconfig:remote.*.url:https://github.com/**"]
    path = ~/.gitconfig-personal

# 公司 GitLab 用公司邮箱
[includeIf "hasconfig:remote.*.url:https://gitlab.company.com/**"]
    path = ~/.gitconfig-work

{{ if lookPath "delta" -}}
[core]
    pager = delta
[interactive]
    diffFilter = delta --color-only
[delta]
    navigate = true  # use n and N to move between diff sections
    dark = true      # or light = true, or omit for auto-detection
{{ end -}}
